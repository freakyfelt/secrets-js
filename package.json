{
  "name": "@freakyfelt/secrets-js",
  "version": "1.2.0",
  "description": "Client library to make secrets fetching easy and safe",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "build:check": "tsdown --publint --attw",
    "prepublishOnly": "npm run build && npm run build:check",
    "ci": "npm run types:check && npm run test:ci && npm run lint && npm run format:check && npm run build",
    "clean": "rm -rf dist",
    "format": "prettier -w src test",
    "format:check": "prettier -c src test",
    "lint": "tsc && npm run format:check",
    "test": "tsx --test src/*.test.ts src/**/*.test.ts && npm run format",
    "test:ci": "tsx --test src/*.test.ts src/**/*.test.ts",
    "types:check": "tsc --noEmit"
  },
  "keywords": [
    "aws",
    "secrets",
    "manager",
    "secretsmanager"
  ],
  "author": "Bruce Felt",
  "license": "MIT",
  "files": [
    "dist/**/*"
  ],
  "peerDeependencies": {
    "@aws-sdk/client-secrets-manager": "3.x"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@aws-sdk/client-secrets-manager": "^3.936.0",
    "@testcontainers/localstack": "^11.8.1",
    "@tsconfig/node22": "^22.0.5",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.3",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}
